{%- comment -%}
  Inline SVG icons. Pass `name` — one of the cases below.
  All icons are 24×24 on a 0,0,24,24 viewBox, stroke-based, so they
  pick up the current text color (`currentColor`) and line up with
  typographic size via width: 1em.
{%- endcomment -%}
{%- case name -%}
  {%- when 'menu' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <path d="M4 7h16M4 12h16M4 17h16"/>
    </svg>
  {%- when 'close' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <path d="M6 6l12 12M18 6L6 18"/>
    </svg>
  {%- when 'search' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
    </svg>
  {%- when 'user' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <circle cx="12" cy="8" r="4"/><path d="M4 21c1.5-4 4.5-6 8-6s6.5 2 8 6"/>
    </svg>
  {%- when 'bag' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="M5 8h14l-1 12H6L5 8Z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/>
    </svg>
  {%- when 'moon' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <path d="M20 15.5A8 8 0 1 1 8.5 4a7 7 0 0 0 11.5 11.5Z"/>
    </svg>
  {%- when 'chevron-down' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  {%- when 'chevron-up' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 15 6-6 6 6"/>
    </svg>
  {%- when 'arrow-right' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14M13 6l6 6-6 6"/>
    </svg>
  {%- when 'truck' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="M2 7h12v9H2zM14 11h4l3 3v2h-7z"/>
      <circle cx="6.5" cy="17.5" r="1.7"/><circle cx="17.5" cy="17.5" r="1.7"/>
    </svg>
  {%- when 'leaf' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 19c6 0 12-5 14-14-9 0-14 5-14 14Z"/><path d="M5 19c0-3 2-7 7-9"/>
    </svg>
  {%- when 'shield' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6l8-3z"/>
    </svg>
  {%- when 'package' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="M12 3 3 7.5v9L12 21l9-4.5v-9z"/><path d="M3 7.5 12 12l9-4.5M12 12v9"/>
    </svg>
  {%- when 'star' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="m12 3 2.7 5.8 6.3.9-4.6 4.5 1.1 6.3L12 17.9l-5.5 2.6 1.1-6.3L3 9.7l6.3-.9z"/>
    </svg>
  {%- when 'heart' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="M12 20s-7-4.5-7-10a4.5 4.5 0 0 1 7-3.5A4.5 4.5 0 0 1 19 10c0 5.5-7 10-7 10z"/>
    </svg>
  {%- when 'sparkle' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.5 5.5l2.5 2.5M16 16l2.5 2.5M5.5 18.5 8 16M16 8l2.5-2.5"/>
    </svg>
  {%- when 'clock' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
    </svg>
  {%- when 'instagram' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
      <rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
    </svg>
  {%- when 'tiktok' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M14 3h3a5 5 0 0 0 4 5v3a8 8 0 0 1-4-1v6a6 6 0 1 1-6-6v3a3 3 0 1 0 3 3V3z"/>
    </svg>
  {%- when 'twitter' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M3 3h4.5L12 9 16.5 3H21l-7 8.6L21 21h-4.5L12 14.5 7.5 21H3l7-8.6z"/>
    </svg>
  {%- when 'facebook' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M13 22v-8h3l1-4h-4V7.5c0-1.2.4-2 2.2-2H17V2.2C16.7 2.1 15.6 2 14.4 2 11.9 2 10 3.6 10 6.7V10H7v4h3v8z"/>
    </svg>
  {%- when 'youtube' -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
      <path d="M23 7.5a4 4 0 0 0-2.8-2.8C18.2 4 12 4 12 4s-6.2 0-8.2.7A4 4 0 0 0 1 7.5C.3 9.5.3 12 .3 12s0 2.5.7 4.5a4 4 0 0 0 2.8 2.8C5.8 20 12 20 12 20s6.2 0 8.2-.7a4 4 0 0 0 2.8-2.8c.7-2 .7-4.5.7-4.5s0-2.5-.7-4.5zM10 15.5v-7l6 3.5z"/>
    </svg>
  {%- else -%}
    <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
      <circle cx="12" cy="12" r="9"/>
    </svg>
{%- endcase -%}
