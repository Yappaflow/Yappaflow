{%- comment -%}
  Single focused call-to-action band.
{%- endcomment -%}
<section class="section cta-block" data-reveal>
  <div class="wrap cta-block__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subhead != blank -%}
      <p class="lede muted">{{ section.settings.subhead }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="btn btn--primary">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "CTA",
  "settings": [
    { "type": "text",     "id": "heading",   "label": "Heading",    "default": "Ready when you are." },
    { "type": "textarea", "id": "subhead",   "label": "Subhead",    "default": "Browse the new arrivals and pick your favorite piece." },
    { "type": "text",     "id": "cta_label", "label": "CTA label",  "default": "Shop now" },
    { "type": "url",      "id": "cta_link",  "label": "CTA link",   "default": "/collections/all" }
  ],
  "presets": [{ "name": "CTA" }]
}
{% endschema %}
