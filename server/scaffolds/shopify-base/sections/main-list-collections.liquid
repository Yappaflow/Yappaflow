{%- comment -%}
  All-collections index page.
{%- endcomment -%}
<section class="section">
  <div class="wrap">
    <header class="section__head" data-reveal>
      <h1 class="heading">{{ section.settings.heading | default: page_title }}</h1>
    </header>

    <div class="collection-grid collection-grid--{{ section.settings.per_row }}">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' -%}
          <a href="{{ collection.url }}" class="collection-tile" data-reveal>
            <div class="collection-tile__media">
              {%- if collection.image != blank -%}
                <img src="{{ collection.image | image_url: width: 900 }}"
                     alt="{{ collection.image.alt | default: collection.title | escape }}"
                     loading="lazy" width="600" height="800">
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <h3 class="collection-tile__title">{{ collection.title }}</h3>
            <p class="muted small">
              {{- 'collections.general.products_count' | t: count: collection.products_count -}}
            </p>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection" },
    { "type": "range","id": "per_row", "label": "Per row", "min": 2, "max": 4, "step": 1, "default": 3 },
    {
      "type": "select","id": "sort","label": "Sort",
      "options": [
        { "value": "manual",           "label": "Manual" },
        { "value": "alphabetical",     "label": "Alphabetical" }
      ],
      "default": "manual"
    }
  ]
}
{% endschema %}
