{%- comment -%}
  FAQ — accessible disclosure list. Interaction handled in theme.js.
{%- endcomment -%}
<section class="section">
  <div class="wrap wrap--prose">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="section__head">
        {%- if section.settings.heading    != blank -%}<h2 class="heading"    data-reveal>{{ section.settings.heading    }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p  class="subheading muted" data-reveal>{{ section.settings.subheading }}</p>{%- endif -%}
      </header>
    {%- endif -%}

    <div class="faq">
      {%- for block in section.blocks -%}
        <div class="faq__item" data-faq-item>
          <button type="button" class="faq__trigger" data-faq-trigger
                  aria-expanded="false" aria-controls="faq-{{ block.id }}">
            <span>{{ block.settings.question }}</span>
            <span class="faq__chevron" aria-hidden="true">{%- render 'icon', name: 'chevron-down' -%}</span>
          </button>
          <div id="faq-{{ block.id }}" class="faq__panel" data-faq-panel hidden>
            {{ block.settings.answer }}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "Questions, answered" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Anything else — ask us, we read every email." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Question",
      "settings": [
        { "type": "text",     "id": "question", "label": "Question", "default": "A common question?" },
        { "type": "richtext", "id": "answer",   "label": "Answer",   "default": "<p>A clear, concrete answer.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "item" }, { "type": "item" }, { "type": "item" }, { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
