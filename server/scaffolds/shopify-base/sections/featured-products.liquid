{%- comment -%}
  Featured products — HYBRID render path.

    1. Real products exist on the store (collection.products.size > 0)
       → Liquid loop over the configured collection. This is what
         runs once the merchant has imported the generated products.csv.

    2. No products yet (typical for a ZIP preview before CSV import,
       or just an empty store)
       → Fall back to static blocks populated by the Yappaflow
         generator at build-time from identity.products. That way the
         preview the user sees in the dashboard looks correct, even
         when the actual Shopify store has nothing in it yet.

  The block definitions live in the {% schema %} at the bottom. The
  generator writes one block per product into config/settings_data.json.

  The two branches share the same <article class="product-card"> markup
  so the styling is consistent either way.
{%- endcomment -%}

{%- assign c = collections[section.settings.collection] -%}
{%- assign per_row = section.settings.products_per_row | default: 3 -%}

<section class="section featured-products">
  <div class="wrap">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="section__head">
        {%- if section.settings.heading != blank -%}
          <h2 class="heading" data-reveal>{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="subheading muted" data-reveal>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="product-grid product-grid--{{ per_row }}">
      {%- if c.products.size > 0 -%}
        {%- for product in c.products limit: section.settings.products_per_page | default: 12 -%}
          {%- render 'product-card',
              product:     product,
              show_vendor: section.settings.show_vendor -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%}Fallback: static blocks written by the generator.{%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'static_product' -%}
              {%- render 'product-card-static', block: block -%}
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <p class="muted" style="grid-column: 1 / -1;">
            No products yet. They'll appear here as soon as the CSV is imported.
          </p>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div class="section__foot" data-reveal>
        <a href="{{ section.settings.cta_link }}" class="btn btn--ghost">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text",       "id": "heading",    "label": "Heading",    "default": "This week's picks" },
    { "type": "text",       "id": "subheading", "label": "Subheading", "default": "Six pieces the studio is leaning on right now." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "range", "id": "products_per_row", "label": "Products per row",
      "min": 2, "max": 4, "step": 1, "default": 3
    },
    {
      "type": "range", "id": "products_per_page", "label": "Max products",
      "min": 3, "max": 24, "step": 3, "default": 6
    },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "text",     "id": "cta_label",   "label": "CTA label",   "default": "Browse all" },
    { "type": "url",      "id": "cta_link",    "label": "CTA link",    "default": "/collections/all" }
  ],
  "blocks": [
    {
      "type": "static_product",
      "name": "Static product (fallback)",
      "limit": 24,
      "settings": [
        { "type": "text",         "id": "title",        "label": "Title" },
        { "type": "textarea",     "id": "description",  "label": "Short description" },
        { "type": "text",         "id": "price",        "label": "Price (display)", "info": "E.g. \"$48\" or \"€39\"" },
        { "type": "text",         "id": "compare_price","label": "Compare-at price (optional)" },
        { "type": "image_picker", "id": "image",        "label": "Image" },
        { "type": "text",         "id": "image_url",    "label": "Image URL (fallback)", "info": "If no image is uploaded, this URL is used." },
        { "type": "url",          "id": "link",         "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    { "name": "Featured products" }
  ]
}
{% endschema %}
