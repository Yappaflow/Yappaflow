{%- comment -%}
  Feature grid — 2-4 value-prop blocks.
{%- endcomment -%}
<section class="section">
  <div class="wrap">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="section__head">
        {%- if section.settings.heading    != blank -%}<h2 class="heading"    data-reveal>{{ section.settings.heading    }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p  class="subheading muted" data-reveal>{{ section.settings.subheading }}</p>{%- endif -%}
      </header>
    {%- endif -%}

    <div class="feature-grid">
      {%- for block in section.blocks -%}
        <article class="feature-card" data-reveal>
          {%- if block.settings.icon != blank -%}
            <div class="feature-card__icon">{%- render 'icon', name: block.settings.icon -%}</div>
          {%- endif -%}
          <h3 class="feature-card__heading">{{ block.settings.heading }}</h3>
          {%- if block.settings.body != blank -%}
            <p class="feature-card__body">{{ block.settings.body }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature grid",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "What you get" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Every shipment leaves the studio on the same terms." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "truck",   "label": "Truck" },
            { "value": "leaf",    "label": "Leaf" },
            { "value": "shield",  "label": "Shield" },
            { "value": "package", "label": "Package" },
            { "value": "star",    "label": "Star" },
            { "value": "heart",   "label": "Heart" },
            { "value": "sparkle", "label": "Sparkle" },
            { "value": "clock",   "label": "Clock" }
          ],
          "default": "star"
        },
        { "type": "text",     "id": "heading", "label": "Heading", "default": "Thoughtful detail" },
        { "type": "textarea", "id": "body",    "label": "Body",    "default": "A short sentence that explains the benefit." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature grid",
      "blocks": [
        { "type": "feature" }, { "type": "feature" },
        { "type": "feature" }, { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
