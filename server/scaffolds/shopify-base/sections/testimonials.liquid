{%- comment -%}
  Testimonials — 2-6 quote blocks in a card grid.
{%- endcomment -%}
<section class="section section--surface">
  <div class="wrap">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="section__head">
        {%- if section.settings.heading    != blank -%}<h2 class="heading"    data-reveal>{{ section.settings.heading    }}</h2>{%- endif -%}
        {%- if section.settings.subheading != blank -%}<p  class="subheading muted" data-reveal>{{ section.settings.subheading }}</p>{%- endif -%}
      </header>
    {%- endif -%}

    <div class="testimonials">
      {%- for block in section.blocks -%}
        <figure class="testimonial" data-reveal>
          <blockquote class="testimonial__quote">“{{ block.settings.quote }}”</blockquote>
          <figcaption class="testimonial__by">
            <strong>{{ block.settings.author }}</strong>
            {%- if block.settings.role != blank -%}
              <span class="muted"> — {{ block.settings.role }}</span>
            {%- endif -%}
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "heading",    "label": "Heading",    "default": "What customers say" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "A handful of notes from the last six months." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote",  "label": "Quote",  "default": "Genuinely the most thoughtful piece I own." },
        { "type": "text",     "id": "author", "label": "Author", "default": "Customer name" },
        { "type": "text",     "id": "role",   "label": "Location or role" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" }, { "type": "testimonial" }, { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
