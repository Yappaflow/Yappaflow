{%- comment -%}
  Account activation page (user invited by the merchant).
{%- endcomment -%}
<section class="section section--center">
  <div class="wrap wrap--prose">
    <h1 class="heading" data-reveal>Activate account</h1>
    <p class="muted" data-reveal>Create your password to finish setting up your account.</p>

    {%- form 'activate_customer_password', class: 'auth-form', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="form-errors" role="alert" data-reveal>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}
      <label class="field">
        <span class="field__label">Password</span>
        <input type="password" name="customer[password]" autocomplete="new-password" required class="field__input">
      </label>
      <label class="field">
        <span class="field__label">Confirm password</span>
        <input type="password" name="customer[password_confirmation]" autocomplete="new-password" required class="field__input">
      </label>
      <button type="submit" class="btn btn--primary btn--full">Activate</button>
    {%- endform -%}
  </div>
</section>
