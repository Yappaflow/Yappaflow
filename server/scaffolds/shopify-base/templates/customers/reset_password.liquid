{%- comment -%}
  Reset password landing page (user arrived via email link).
  Uses the built-in reset_customer_password form.
{%- endcomment -%}
<section class="section section--center">
  <div class="wrap wrap--prose">
    <h1 class="heading" data-reveal>{{ 'customer.recover_password.title' | t }}</h1>

    {%- form 'reset_customer_password', class: 'auth-form', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="form-errors" role="alert" data-reveal>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <label class="field">
        <span class="field__label">New password</span>
        <input type="password" name="customer[password]" autocomplete="new-password" required class="field__input">
      </label>
      <label class="field">
        <span class="field__label">Confirm password</span>
        <input type="password" name="customer[password_confirmation]" autocomplete="new-password" required class="field__input">
      </label>
      <button type="submit" class="btn btn--primary btn--full">Reset password</button>
    {%- endform -%}
  </div>
</section>
