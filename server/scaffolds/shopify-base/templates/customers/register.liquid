{%- comment -%}
  Customer registration. Uses {% form 'create_customer' %}.
{%- endcomment -%}
<section class="section section--center">
  <div class="wrap wrap--prose">
    <h1 class="heading" data-reveal>{{ 'customer.register.title' | t }}</h1>

    {%- form 'create_customer', class: 'auth-form', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="form-errors" role="alert" data-reveal>
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="field-row">
        <label class="field">
          <span class="field__label">{{ 'customer.register.first_name' | t }}</span>
          <input type="text" name="customer[first_name]" autocomplete="given-name" class="field__input">
        </label>
        <label class="field">
          <span class="field__label">{{ 'customer.register.last_name' | t }}</span>
          <input type="text" name="customer[last_name]" autocomplete="family-name" class="field__input">
        </label>
      </div>

      <label class="field">
        <span class="field__label">{{ 'customer.register.email' | t }}</span>
        <input type="email" name="customer[email]" autocomplete="email" required class="field__input">
      </label>

      <label class="field">
        <span class="field__label">{{ 'customer.register.password' | t }}</span>
        <input type="password" name="customer[password]" autocomplete="new-password" required class="field__input">
      </label>

      <button type="submit" class="btn btn--primary btn--full">
        {{ 'customer.register.submit' | t }}
      </button>

      <p class="auth-form__alt">
        <a href="{{ routes.account_login_url }}">{{ 'customer.login.title' | t }}</a>
      </p>
    {%- endform -%}
  </div>
</section>
