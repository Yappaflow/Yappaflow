[
  {
    "name": "theme_info",
    "theme_name": "Yappaflow Base",
    "theme_author": "Yappaflow",
    "theme_version": "1.0.0",
    "theme_documentation_url": "https://yappaflow.com",
    "theme_support_url": "https://yappaflow.com/support"
  },

  {
    "name": "Brand identity",
    "settings": [
      {
        "type": "text",
        "id": "brand_name",
        "label": "Brand name",
        "default": "Yappaflow"
      },
      {
        "type": "textarea",
        "id": "brand_tagline",
        "label": "Tagline",
        "default": "Quietly crafted goods for everyday use."
      },
      {
        "type": "image_picker",
        "id": "brand_logo",
        "label": "Logo",
        "info": "SVG or PNG with transparent background recommended."
      },
      {
        "type": "checkbox",
        "id": "brand_css_enabled",
        "label": "Load brand.css overrides",
        "default": true,
        "info": "Yappaflow writes brand-specific overrides here. Uncheck to use only base defaults."
      }
    ]
  },

  {
    "name": "Colors — light mode",
    "settings": [
      { "type": "color", "id": "color_bg",         "label": "Background",        "default": "#ffffff" },
      { "type": "color", "id": "color_fg",         "label": "Foreground",        "default": "#0a0a0a" },
      { "type": "color", "id": "color_primary",    "label": "Primary action",    "default": "#0a0a0a" },
      { "type": "color", "id": "color_on_primary", "label": "On primary",        "default": "#ffffff" },
      { "type": "color", "id": "color_surface",    "label": "Surface",           "default": "#f6f6f4" },
      { "type": "color", "id": "color_muted",      "label": "Muted text",        "default": "#6b6b6b" },
      { "type": "color", "id": "color_border",     "label": "Border",            "default": "#e6e6e3" },
      { "type": "color", "id": "color_accent",     "label": "Accent",            "default": "#d4a24c" }
    ]
  },

  {
    "name": "Colors — dark mode",
    "settings": [
      { "type": "color", "id": "color_bg_dark",         "label": "Background",     "default": "#0a0a0a" },
      { "type": "color", "id": "color_fg_dark",         "label": "Foreground",     "default": "#f5f5f4" },
      { "type": "color", "id": "color_primary_dark",    "label": "Primary action", "default": "#f5f5f4" },
      { "type": "color", "id": "color_on_primary_dark", "label": "On primary",     "default": "#0a0a0a" },
      { "type": "color", "id": "color_surface_dark",    "label": "Surface",        "default": "#141414" },
      { "type": "color", "id": "color_muted_dark",      "label": "Muted text",     "default": "#a0a0a0" },
      { "type": "color", "id": "color_border_dark",     "label": "Border",         "default": "#262626" },
      { "type": "color", "id": "color_accent_dark",     "label": "Accent",         "default": "#e4b867" }
    ]
  },

  {
    "name": "Typography",
    "settings": [
      {
        "type": "text",
        "id": "font_display_family",
        "label": "Display / heading font-family",
        "default": "ui-serif, Georgia, \"Times New Roman\", serif",
        "info": "CSS font-family stack. Yappaflow usually overrides this with a Google Font or self-hosted stack."
      },
      {
        "type": "text",
        "id": "font_body_family",
        "label": "Body font-family",
        "default": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif"
      }
    ]
  },

  {
    "name": "Social",
    "settings": [
      { "type": "url",  "id": "social_instagram", "label": "Instagram" },
      { "type": "url",  "id": "social_tiktok",    "label": "TikTok" },
      { "type": "url",  "id": "social_twitter",   "label": "Twitter / X" },
      { "type": "url",  "id": "social_facebook",  "label": "Facebook" },
      { "type": "url",  "id": "social_youtube",   "label": "YouTube" }
    ]
  }
]
