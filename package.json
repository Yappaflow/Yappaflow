{
  "name": "yappaflow",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yappaflow/yappaflow.git"
  },
  "bugs": {
    "url": "https://github.com/yappaflow/yappaflow/issues"
  },
  "homepage": "https://yappaflow.com",
  "author": "Yappaflow",
  "license": "UNLICENSED",
  "workspaces": [
    "web",
    "server",
    "shared",
    "tunnel",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@yappaflow/web --filter=@yappaflow/server",
    "dev:all": "turbo dev",
    "dev:web": "turbo dev --filter=@yappaflow/web",
    "dev:server": "turbo dev --filter=@yappaflow/server",
    "dev:tunnel": "turbo dev --filter=@yappaflow/tunnel",
    "build": "turbo build",
    "build:web": "turbo build --filter=@yappaflow/web",
    "build:server": "turbo build --filter=@yappaflow/server",
    "build:shared": "turbo build --filter=@yappaflow/shared",
    "start:mcp": "cd apps/yappaflow-mcp && node dist/mcp/server.js",
    "build:ui": "turbo build --filter=yappaflow-ui",
    "dev:ui": "turbo dev --filter=yappaflow-ui",
    "build:ui-docs": "turbo build --filter=@yappaflow/ui-docs",
    "dev:ui-docs": "turbo dev --filter=@yappaflow/ui-docs",
    "start": "turbo start",
    "lint": "turbo lint",
    "clean": "turbo clean"
  },
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "^2.9.5"
  }
}
