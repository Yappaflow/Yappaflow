{
  "name": "yappaflow-ui",
  "version": "0.1.0",
  "description": "An opinionated React + GSAP component library for art-gallery–grade websites — the design vocabulary for Yappaflow's AI site generator.",
  "author": "Yappaflow",
  "license": "MIT",
  "homepage": "https://ui.yappaflow.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yappaflow/yappaflow-ui.git"
  },
  "bugs": {
    "url": "https://github.com/yappaflow/yappaflow-ui/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./dist/motion/engine.js",
    "./dist/motion/engine.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./motion": {
      "types": "./dist/motion/index.d.ts",
      "import": "./dist/motion/index.js",
      "require": "./dist/motion/index.cjs"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.cjs"
    },
    "./shell": {
      "types": "./dist/shell/index.d.ts",
      "import": "./dist/shell/index.js",
      "require": "./dist/shell/index.cjs"
    },
    "./exhibits": {
      "types": "./dist/exhibits/index.d.ts",
      "import": "./dist/exhibits/index.js",
      "require": "./dist/exhibits/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "lenis": "^1.3.21",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.3.0",
    "typescript": "~5.9.2"
  },
  "keywords": [
    "react",
    "gsap",
    "component-library",
    "design-system",
    "animation",
    "yappaflow"
  ]
}
